# Copy this file to .env.local and fill in from Supabase → Project Settings → API.
# .env.local is git-ignored. NEVER commit real keys.

# Safe in the browser (respects Row Level Security):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# SERVER ONLY — bypasses RLS. Never prefix NEXT_PUBLIC_. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used to build magic-link redirect URLs. Local: http://localhost:3000
# Production: your deployed URL, e.g. https://portal.psyberdigital.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
